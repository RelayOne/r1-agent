{
  "name": "@r1/web",
  "version": "0.1.0",
  "private": true,
  "description": "r1d web chat UI (scaffold; spec 6 web-chat-ui ships the actual components)",
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:mcp": "storybook-mcp serve --config web/.storybook/mcp.config.ts",
    "storybook:mcp:validate": "storybook-mcp validate web/.storybook/mcp.config.ts --fail-on-missing-a11y"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^9.0.0",
    "@storybook/addon-essentials": "^9.0.0",
    "@storybook/addon-interactions": "^9.0.0",
    "@storybook/react": "^9.0.0",
    "@storybook/react-vite": "^9.0.0",
    "storybook": "^9.0.0",
    "storybook-mcp": "^9.0.0",
    "vite": "^5.0.0"
  }
}
