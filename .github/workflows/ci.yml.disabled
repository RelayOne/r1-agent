name: CI

on:
  pull_request:
    branches: [main]
  push:
    branches: [main]

permissions:
  contents: read

jobs:
  build:
    runs-on: ubuntu-latest
    env:
      CGO_ENABLED: "1"
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-go@v5
        with:
          go-version: "1.25.5"

      - name: Install build deps
        run: sudo apt-get update && sudo apt-get install -y gcc

      - name: Build
        run: go build ./cmd/stoke

      - name: Vet
        run: go vet ./...

      - name: Compile deterministic skills
        run: go run ./cmd/r1-skill-compile --check ./skills/deterministic-echo/skill.r1.json

      - name: Test
        run: go test ./... -count=1 -timeout=120s

      - name: Check package count
        run: make check-pkg-count

  race:
    runs-on: ubuntu-latest
    env:
      CGO_ENABLED: "1"
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-go@v5
        with:
          go-version: "1.25.5"

      - name: Install build deps
        run: sudo apt-get update && sudo apt-get install -y gcc

      - name: Test with race detector
        # Race detector is green across the full repo as of the
        # streamjson.TwoLane stop-channel fix. Any new race is a
        # real regression — fail the job.
        run: go test ./... -race -count=1 -timeout=300s

  lint:
    runs-on: ubuntu-latest
    env:
      CGO_ENABLED: "1"
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-go@v5
        with:
          go-version: "1.25.5"

      - name: Install build deps
        run: sudo apt-get update && sudo apt-get install -y gcc

      - name: golangci-lint
        # Build from source with setup-go 1.25.5 (pre-built v1.64.8
        # binaries ship with Go 1.24 and refuse to run against a 1.25.5
        # target). The golangci/golangci-lint-action@v6 had supported
        # install-mode: goinstall but the action itself exits non-zero
        # on findings with no wrap-for-warning option — so invoke
        # directly so the job can surface findings as a CI warning
        # (matching the govulncheck + gosec pragma: the codebase has
        # accumulated 600+ findings across unused/revive/prealloc/
        # nilerr/govet/exhaustive/goconst/predeclared/gocritic; they
        # surface but don't block PRs until a one-shot lint sweep
        # lands in a dedicated PR).
        run: |
          go install github.com/golangci/golangci-lint/cmd/golangci-lint@v1.64.8
          golangci-lint run --timeout=5m > golangci-lint.txt 2>&1 && echo "lint clean" || {
            echo "::warning::golangci-lint flagged issues (see attached report; tracked for cleanup)"
            head -120 golangci-lint.txt
            # Exit 0 — findings are advisory until the backlog PR lands.
          }

  security:
    runs-on: ubuntu-latest
    env:
      CGO_ENABLED: "1"
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-go@v5
        with:
          go-version: "1.25.5"

      - name: Install build deps
        run: sudo apt-get update && sudo apt-get install -y gcc

      - name: govulncheck
        # govulncheck emits ##[error] annotations for each stdlib/third-party
        # trace even when invoked with || echo "::warning::", and GitHub
        # marks the job FAILURE whenever any ##[error] annotation fires.
        # Route output to a file so annotations don't reach the Actions
        # parser; print a human summary instead.
        run: |
          go install golang.org/x/vuln/cmd/govulncheck@latest
          govulncheck ./... > govulncheck.txt 2>&1 && echo "No vulnerabilities" || {
            echo "::warning::govulncheck found vulnerabilities (report attached)"
            head -80 govulncheck.txt
          }
          # Exit 0: stdlib vulns require a Go version upgrade, not a
          # code change, and third-party vulns are surfaced as warnings
          # but don't block PRs while the upgrade cadence stabilizes.

      - name: gosec
        # Build gosec from source with the runner's Go 1.25.5 rather
        # than using securego/gosec@v2.21.4 which runs in a Docker
        # image shipping Go 1.23.1 — that combo fails go.mod's "go
        # >= 1.25.5" check on every package. Narrow scan to
        # production packages; corpus/* are independent benchmark
        # modules with their own go.mod.
        run: |
          go install github.com/securego/gosec/v2/cmd/gosec@v2.22.4
          gosec -exclude=G104,G304 -exclude-dir=corpus -exclude-dir=bench ./cmd/... ./internal/... || {
            echo "::warning::gosec flagged issues (review output above; G104+G304 already excluded)"
          }
